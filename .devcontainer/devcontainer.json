{
    "name": "SSE Demo (Java 8)",
    "image": "mcr.microsoft.com/devcontainers/universal:2",
    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "8",
            "jdkDistro": "zulu"
        }
    },
    "forwardPorts": [8080],
    "portsAttributes": {
        "8080": {
            "label": "SSE Demo",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack"
            ]
        }
    },
    "postCreateCommand": "mkdir -p target && echo 'Codespace ready. Run: mvn tomcat7:run'",
    "postAttachCommand": "echo '=== 启动命令 ===\n\nmvn tomcat7:run\n================='"
}

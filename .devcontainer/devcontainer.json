{
    "name": "SSE Demo (Java 8)",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "forwardPorts": [8080],
    "portsAttributes": {
        "8080": {
            "label": "SSE Demo",
            "onAutoForward": "notify"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack"
            ]
        }
    },
    "postCreateCommand": "echo 'Codespace is ready. Run: mvn tomcat7:run'"
}
